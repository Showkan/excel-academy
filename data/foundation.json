            "Workbook va Worksheet farqi"
          ],
          "content": [
            { "type": "heading", "level": 2, "text": "Excel nima?" },
            { "type": "paragraph", "text": "Excel — Microsoft Office paketiga kiruvchi elektron jadval dasturi. U raqamlar, matnlar va formulalar bilan ishlash uchun mo'ljallangan." },
            { "type": "heading", "level": 3, "text": "Asosiy tushunchalar" },
            { "type": "list", "items": ["<strong>Workbook</strong> — Excel fayli (.xlsx)", "<strong>Worksheet (Sheet)</strong> — Workbook ichidagi bitta varaq", "<strong>Cell (Katak)</strong> — Bitta hujayra (masalan: A1)", "<strong>Row (Qator)</strong> — Gorizontal qator (1, 2, 3...)", "<strong>Column (Ustun)</strong> — Vertikal ustun (A, B, C...)"] },
            { "type": "note", "text": "Excel'da har bir varaq <strong>1,048,576 qator</strong> va <strong>16,384 ustun</strong> (XFD gacha) bo'ladi." }
          ],
          "shortcuts": [
            { "action": "Yangi Workbook", "keys": "Ctrl + N" },
            { "action": "Saqlash", "keys": "Ctrl + S" }
          ],
          "examples": [
            {
              "title": "Katak manzili",
              "description": "A1 = ustun A, qator 1",
              "table": { "headers": ["", "A", "B", "C"], "rows": [["1", "A1", "B1", "C1"], ["2", "A2", "B2", "C2"]] }
            }
          ],
          "sim": {
            "cols": ["A", "B", "C", "D", "E", "F"],
            "rows": 3,
