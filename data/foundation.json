            { "type": "heading", "level": 2, "text": "Formula nima?" },
            { "type": "paragraph", "text": "Formula — bu Excel'da hisob-kitob qilish uchun yozma ifoda. Har qanday formula <strong>=</strong> (teng) belgisi bilan boshlanadi." },
            { "type": "code", "code": "=A1+B1\n=SUM(A1:A10)" }
          ],
          "formulas": [
            { "name": "SUM", "formula": "=SUM(A1:A10)", "description": "A1 dan A10 gacha bo'lgan barcha sonlar yig'indisi" },
            { "name": "AVERAGE", "formula": "=AVERAGE(A1:A10)", "description": "O'rtacha qiymat" }
          ],
          "sim": {
            "cols": ["A", "B", "C", "D"],
            "rows": 4,
            "preset": { "A1": "Mahsulot", "B1": "Soni", "C1": "Narxi", "A2": "Olma", "B2": 10, "C2": 5000, "A3": "Banan", "B3": 15, "C3": 3000, "A4": "Apelsin", "B4": 20, "C4": 4500 },
            "locked": ["A1", "B1", "C1", "A2", "B2", "C2", "A3", "B3", "C3", "A4", "B4", "C4"],
            "task": "D2 katakka B2 va C2 ni ko'paytiruvchi formula yozing (=B2*C2)",
            "expected": { "D2": 50000 },
            "tolerance": 0
